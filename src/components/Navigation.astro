        <li class="sm-panel-itemWrap"><a class={`sm-panel-item${activePage === 'download' ? ' active' : ''}`} href="/download" data-page="download" aria-label="资源下载"><span class="sm-panel-itemLabel">资源下载</span></a></li>
      </ul>
      <div class="sm-socials">
