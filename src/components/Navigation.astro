---
import MusicPlayer from "./MusicPlayer.astro";

const pathname = Astro.request.url.replace(/https?:\/\/[^/]+/, '').split('?')[0];
const activePage =
	pathname === '/' || pathname === '/index.html'
		? 'index'
		: pathname.startsWith('/live')
			? 'live'
			: pathname.startsWith('/gallery')
				? 'gallery'
				: pathname.startsWith('/activity')
					? 'activity'
					: pathname.startsWith('/about')
						? 'about'
						: pathname.startsWith('/download')
							? 'download'
							: 'index';
---

<nav class="nav-sidebar" aria-label="主导航">
  <div class="nav-logo">
    <img src="/img/mobile-icon.webp" alt="HXK" width="48" height="48" decoding="async" loading="lazy" />
  </div>
  <div class="music-player-wrapper">
    <MusicPlayer />
  </div>
  <ul class="nav-items">
    <li class={`nav-item${activePage === 'index' ? ' active' : ''}`} data-page="index">
      <a href="/" data-page="index" class={activePage === 'index' ? 'active' : ''}>
        <span class="nav-item-zh">主页</span>
        <span class="nav-item-en">HOME</span>
      </a>
    </li>
    <li class={`nav-item${activePage === 'live' ? ' active' : ''}`} data-page="live">
      <a href="/live" data-page="live" class={activePage === 'live' ? 'active' : ''}>
        <span class="nav-item-zh">足迹</span>
        <span class="nav-item-en">LIVE</span>
      </a>
    </li>
    <li class={`nav-item${activePage === 'gallery' ? ' active' : ''}`} data-page="gallery">
      <a href="/gallery" data-page="gallery" class={activePage === 'gallery' ? 'active' : ''}>
        <span class="nav-item-zh">插画一览</span>
        <span class="nav-item-en">GALLERY</span>
      </a>
    </li>
    <li class={`nav-item${activePage === 'activity' ? ' active' : ''}`} data-page="activity">
      <a href="/activity" data-page="activity" class={activePage === 'activity' ? 'active' : ''}>
        <span class="nav-item-zh">当期活动</span>
        <span class="nav-item-en">ACTIVITY</span>
      </a>
    </li>
    <li class={`nav-item${activePage === 'about' ? ' active' : ''}`} data-page="about">
      <a href="/about" data-page="about" class={activePage === 'about' ? 'active' : ''}>
        <span class="nav-item-zh">关于我们</span>
        <span class="nav-item-en">ABOUT</span>
      </a>
    </li>
    <li class={`nav-item${activePage === 'download' ? ' active' : ''}`} data-page="download">
      <a href="/download" data-page="download" class={activePage === 'download' ? 'active' : ''}>
        <span class="nav-item-zh">资源下载</span>
        <span class="nav-item-en">SHARE</span>
      </a>
    </li>
  </ul>
  <div class="nav-sidebar-footer">
    <a href="https://space.bilibili.com/672455305" data-href="https://space.bilibili.com/672455305?spm_id_from=333.337.0.0" target="_blank" rel="noopener noreferrer" class="nav-bili-link">
