<div class="sm-wrapper" data-position="right">
  <div class="sm-prelayers">
    <div class="sm-prelayer"></div>
    <div class="sm-prelayer"></div>
  </div>
  <header class="sm-header">
    <div class="sm-logo">
      <img src="/img/mobile-icon.webp" alt="HXK" class="sm-logo-img" decoding="async" loading="lazy" />
    </div>
    <button class="sm-toggle" aria-label="打开菜单" aria-expanded="false" type="button">
      <span class="sm-toggle-textWrap">
        <span class="sm-toggle-textInner">
          <span class="sm-toggle-line">Menu</span>
          <span class="sm-toggle-line">Close</span>
        </span>
      </span>
      <span class="sm-icon">
        <span class="sm-icon-line"></span>
        <span class="sm-icon-line sm-icon-line-v"></span>
      </span>
    </button>
  </header>
