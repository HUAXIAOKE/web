---
import SubLayout from "../../layouts/SubLayout.astro";
---

<SubLayout title="活动报名 - Huaxiaoke" description="华小科活动报名">
  <div class="signup-page" id="signup-page">
    <div class="signup-hero">
      <div class="signup-hero-media" id="signup-hero-media"></div>
      <div class="signup-hero-overlay"></div>
      <div class="signup-hero-content">
        <p class="signup-hero-kicker">ACTIVITY SIGN UP</p>
        <h1 class="signup-hero-title" id="signup-hero-title">加载中...</h1>
        <div class="signup-hero-meta" id="signup-hero-meta"></div>
      </div>
    </div>

    <div class="signup-form-card">
      <h2>请报名</h2>
      <p class="form-subtitle">提交前请先阅读注意事项哦～</p>

      <form class="signup-form" id="signup-form">
        <div id="signup-form-fields"></div>
        <div id="signup-attachment-field" class="signup-field" style="display:none">
          <label>附件<span class="required">*</span></label>
          <div class="signup-file-wrap" id="signup-file-wrap">
            <input type="file" id="attachment" name="attachment" accept=".zip,.rar,.7z,.tar,.bz2,.tar.xz,.tar.gz,.tgz,application/zip,application/x-rar-compressed,application/x-7z-compressed" />
            <label for="attachment" class="signup-file-trigger">
              <i class="fas fa-cloud-upload-alt signup-file-icon"></i>
              <span class="signup-file-text">点击或拖拽上传压缩包</span>
            </label>
            <div class="signup-file-list" id="signup-file-list"></div>
          </div>
        </div>

        <div class="signup-actions">
          <button type="submit" class="signup-submit">提交报名</button>
          <a href="/activity" class="signup-back" onclick="event.preventDefault();document.querySelector('.signup-page').classList.add('fade-out');setTimeout(()=>{location.href='/activity'},250)">
            <i class="fas fa-arrow-left"></i>
            返回活动列表
          </a>
        </div>
      </form>
    </div>

    <div class="signup-detail-card" id="signup-instructions">
      <h3>递交须知</h3>
      <div id="signup-instructions-content"></div>
    </div>
  </div>

  <script is:inline>
    (async () => {
      const API = window.API_BASE || '';
      const params = new URLSearchParams(window.location.search);
      const activityId = params.get('activityId');
      if (!activityId) {
        window.location.href = '/activity';
        return;
      }

      try {
        const [actRes, formRes] = await Promise.all([
          fetch(API + '/api/activities'),
          fetch(API + '/api/activity/' + activityId + '/signup-form'),
        ]);

        if (!actRes.ok || !formRes.ok) throw new Error('加载失败');

        const activities = await actRes.json();
        const activity = activities.find((a) => a.id === parseInt(activityId));
        if (!activity) {
          window.location.href = '/activity';
          return;
        }

        if (activity.signupStatus !== 'active') {
          window.location.href = '/activity';
          return;
        }

        const form = await formRes.json();

        document.getElementById('signup-hero-title').textContent = activity.headline;
        document.getElementById('signup-hero-media').style.backgroundImage = `url('${activity.image}')`;

        const meta = document.getElementById('signup-hero-meta');
        meta.innerHTML = (activity.tags || '')
          .split(',')
          .filter(Boolean)
          .map((t) => `<span class="signup-hero-tag">${t}</span>`)
          .join('') + `<span class="signup-hero-date">${activity.date}</span>`;

        const fields = JSON.parse(form.fields || '[]');
        const fieldsContainer = document.getElementById('signup-form-fields');
        fieldsContainer.innerHTML = fields
          .map((f) => {
            if (f.type === 'textarea') {
              return `<div class="signup-field">
                <label for="${f.name}">${f.label}${f.required ? '<span class="required">*</span>' : ''}</label>
                <textarea id="${f.name}" name="${f.name}" placeholder="${f.placeholder || ''}" ${f.required ? 'required' : ''}></textarea>
              </div>`;
            }
            return `<div class="signup-field">
              <label for="${f.name}">${f.label}${f.required ? '<span class="required">*</span>' : ''}</label>
              <input type="text" id="${f.name}" name="${f.name}" placeholder="${f.placeholder || ''}" ${f.required ? 'required' : ''} />
            </div>`;
          })
          .join('');

        if (fields.length > 2) {
          const firstTwo = fieldsContainer.children;
          if (firstTwo.length >= 2) {
            const row = document.createElement('div');
            row.className = 'signup-form-row';
            row.appendChild(firstTwo[0]);
            row.appendChild(firstTwo[1]);
            fieldsContainer.insertBefore(row, fieldsContainer.firstChild);
          }
        }

        if (form.attachment) {
          document.getElementById('signup-attachment-field').style.display = '';
        }

        const instructionsContent = document.getElementById('signup-instructions-content');
        if (form.instructions) {
          instructionsContent.innerHTML = form.instructions;
        } else {
          document.getElementById('signup-instructions').style.display = 'none';
        }

        const attachmentInput = document.getElementById('attachment');
        const fileWrap = document.getElementById('signup-file-wrap');
        const fileList = document.getElementById('signup-file-list');
        let uploadedAttachmentUrl = '';
        let currentFile = null;
        let uploadState = 'idle';
        let uploadPct = 0;

        const archiveExt = /\.(zip|rar|7z|tgz|gz|bz2|xz)$/i;
        function isArchiveFile(file) {
          const name = file.name.toLowerCase();
          return archiveExt.test(name) || name.endsWith('.tar.gz') || name.endsWith('.tar.bz2') || name.endsWith('.tar.xz');
        }

        function renderFileList() {
          fileList.innerHTML = '';
          fileWrap.classList.remove('has-value', 'is-uploading', 'is-ready', 'is-error');
          if (!currentFile) return;

          fileWrap.classList.add('has-value');
          if (uploadState === 'uploading') fileWrap.classList.add('is-uploading');
          if (uploadState === 'ready') fileWrap.classList.add('is-ready');
          if (uploadState === 'error') fileWrap.classList.add('is-error');

          const item = document.createElement('div');
          item.className = 'signup-file-item';

          const preview = document.createElement('div');
          preview.className = 'signup-file-preview';
          preview.innerHTML = '<i class="fas fa-file-archive"></i>';
          item.appendChild(preview);

          const info = document.createElement('div');
          info.className = 'signup-file-info';
          const name = document.createElement('span');
          name.className = 'signup-file-name';
          name.textContent = currentFile.name;
          info.appendChild(name);

          if (uploadState === 'uploading') {
            const status = document.createElement('span');
            status.className = 'signup-file-status';
            status.textContent = '上传中 ' + uploadPct + '%';
            info.appendChild(status);
          } else if (uploadState === 'ready') {
            const status = document.createElement('span');
            status.className = 'signup-file-status is-done';
            status.textContent = '已上传';
            info.appendChild(status);
          } else if (uploadState === 'error') {
            const status = document.createElement('span');
            status.className = 'signup-file-status is-error';
            status.textContent = '上传失败';
            info.appendChild(status);
          }
          item.appendChild(info);

          const remove = document.createElement('button');
          remove.type = 'button';
          remove.className = 'signup-file-remove';
          remove.setAttribute('aria-label', '删除');
          remove.innerHTML = '<i class="fas fa-times"></i>';
          remove.addEventListener('click', resetAttachment);
          item.appendChild(remove);

          fileList.appendChild(item);
        }

        function resetAttachment() {
          uploadedAttachmentUrl = '';
          currentFile = null;
          uploadState = 'idle';
          uploadPct = 0;
          attachmentInput.value = '';
          renderFileList();
        }

        function parseUploadError(text) {
          if (!text) return '上传失败';
          try {
            const json = JSON.parse(text);
            return json.message || json.error || text;
          } catch {
            return text.replace(/^[^:]+:\s*/, '').trim() || text;
          }
        }

        function uploadEndpoint() {
          if (window.location.port === '4321') return 'http://localhost:1037/api/signup/upload';
          return (API || '') + '/api/signup/upload';
        }

        function uploadFile(file) {
          return new Promise((resolve, reject) => {
            const xhr = new XMLHttpRequest();
            const fd = new FormData();
            fd.append('file', file);
            xhr.upload.onprogress = (ev) => {
              if (ev.lengthComputable) {
                uploadPct = Math.round((ev.loaded / ev.total) * 100);
                const status = fileList.querySelector('.signup-file-status');
                if (status) status.textContent = '上传中 ' + uploadPct + '%';
              }
            };
            xhr.onload = () => {
              if (xhr.status === 200) {
                resolve(JSON.parse(xhr.responseText));
              } else {
                reject(new Error(parseUploadError(xhr.responseText)));
              }
            };
            xhr.onerror = () => reject(new Error('网络错误，请确认后端已启动'));
            xhr.open('POST', uploadEndpoint());
            xhr.send(fd);
          });
        }

        async function handleFile(file) {
          if (!file) return;
          if (!isArchiveFile(file)) {
            alert('仅支持 zip / rar / 7z / tar.gz 等压缩包格式');
            return;
          }
          if (file.size > 500 * 1024 * 1024) {
            alert('文件过大，最大允许 500 MB');
            return;
          }
          currentFile = file;
          uploadState = 'uploading';
          uploadPct = 0;
          uploadedAttachmentUrl = '';
          renderFileList();
          try {
            const result = await uploadFile(file);
            uploadedAttachmentUrl = result.url;
            uploadState = 'ready';
            renderFileList();
          } catch {
            uploadState = 'error';
            renderFileList();
          }
        }

        attachmentInput.addEventListener('change', () => {
          if (attachmentInput.files[0]) handleFile(attachmentInput.files[0]);
          attachmentInput.value = '';
        });

        fileWrap.addEventListener('dragover', (e) => {
          e.preventDefault();
          e.stopPropagation();
          fileWrap.classList.add('signup-file-dragover');
        });
        fileWrap.addEventListener('dragleave', (e) => {
          e.preventDefault();
          if (!fileWrap.contains(e.relatedTarget)) fileWrap.classList.remove('signup-file-dragover');
        });
        fileWrap.addEventListener('drop', (e) => {
          e.preventDefault();
          e.stopPropagation();
          fileWrap.classList.remove('signup-file-dragover');
          const file = e.dataTransfer.files[0];
          if (file) handleFile(file);
        });

        document.getElementById('signup-form').addEventListener('submit', async (e) => {
          e.preventDefault();
          const btn = e.target.querySelector('.signup-submit');
          btn.disabled = true;
          btn.textContent = '提交中...';

          const formData = new FormData(e.target);
          const data = {};
          fields.forEach((f) => {
            data[f.name] = formData.get(f.name) || '';
          });

          const attachments = [];
          if (form.attachment) {
            if (!uploadedAttachmentUrl) {
              btn.textContent = '请先上传压缩包';
              btn.disabled = false;
              setTimeout(() => { btn.textContent = '提交报名'; }, 2500);
              return;
            }
            attachments.push(uploadedAttachmentUrl);
          }

          btn.textContent = '提交报名中...';
          const submitRes = await fetch(API + '/api/activity/' + activityId + '/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              data: JSON.stringify(data),
              attachments: JSON.stringify(attachments),
            }),
          });

          if (submitRes.ok) {
            await submitRes.json();
            btn.textContent = '提交成功！';
            btn.disabled = false;
            setTimeout(() => { btn.textContent = '提交报名'; }, 2500);
          } else {
            const err = await submitRes.text();
            btn.textContent = err || '提交失败';
            btn.disabled = false;
            setTimeout(() => {
              btn.textContent = '提交报名';
            }, 3000);
          }
        });
      } catch (err) {
        document.getElementById('signup-hero-title').textContent = '加载失败';
      }
    })();
  </script>
</SubLayout>