---
import activity001 from "../../assets/img/activity001.png";
import activity002 from "../../assets/img/activity002.png";
import signupArt from "../../assets/img/signup.svg";
import "../../styles/activity-now.css";

const maskStyle = `-webkit-mask-image: url('${signupArt.src}'); mask-image: url('${signupArt.src}');`;
const waveLayers = ['se-w1', 'se-w2', 'se-w3', 'se-w4'];
const chunks = [
	{ left: 0, right: 83.33 },
	{ left: 16.67, right: 66.67 },
	{ left: 33.33, right: 50 },
	{ left: 50, right: 33.33 },
	{ left: 66.67, right: 16.67 },
	{ left: 83.33, right: 0 },
];
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>正在报名 - Huaxiaoke</title>
  <meta name="description" content="华小科活动报名" />
</head>
<body>
  <div class="activity-now-page">
    <div class="activity-now-bg" style={`background-image: url('${activity001.src}')`}></div>
    <div class="activity-now-overlay"></div>

    <div class="activity-now-content">
      <p class="activity-now-kicker">Activity Registration</p>
      <h1 class="activity-now-title">新生歌会</h1>
    </div>

    <button class="signup-entry" id="signup-entry" type="button" aria-label="立即报名">
      <span class="se-layer se-outline" style={maskStyle}></span>
      {chunks.map((c) => (
        <span class="se-chunk" style={`clip-path: inset(-10% ${c.right}% -10% ${c.left}%);`}>
          {waveLayers.map((layerCls) => (
            <span class={`se-layer ${layerCls}`} style={maskStyle}></span>
          ))}
          <span class="se-layer se-liquid" style={maskStyle}>
            <span class="se-liquid-wave se-liquid-wave-a"></span>
            <span class="se-liquid-wave se-liquid-wave-b"></span>
          </span>
        </span>
      ))}
    </button>

    <div class="waves tide-enter" id="waves" aria-hidden="true">
      <div class="wave wave-1">
        <svg viewBox="0 0 2880 320" preserveAspectRatio="none">
          <path d="M0,40 C240,0 480,80 720,40 C960,0 1200,80 1440,40 C1680,0 1920,80 2160,40 C2400,0 2640,80 2880,40 L2880,320 L0,320 Z" />
        </svg>
      </div>
      <div class="wave wave-2">
        <svg viewBox="0 0 2880 320" preserveAspectRatio="none">
          <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 C1680,80 1920,0 2160,40 C2400,80 2640,0 2880,40 L2880,320 L0,320 Z" />
        </svg>
      </div>
      <div class="wave wave-3">
        <svg viewBox="0 0 2880 320" preserveAspectRatio="none">
          <path d="M0,40 C240,0 480,80 720,40 C960,0 1200,80 1440,40 C1680,0 1920,80 2160,40 C2400,0 2640,80 2880,40 L2880,320 L0,320 Z" />
        </svg>
      </div>
      <div class="wave wave-4">
        <svg viewBox="0 0 2880 320" preserveAspectRatio="none">
          <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 C1680,80 1920,0 2160,40 C2400,80 2640,0 2880,40 L2880,320 L0,320 Z" />
        </svg>
      </div>
    </div>

    <div class="waves-side" id="waves-side" aria-hidden="true">
      <div class="wave-side wave-side-1">
        <svg viewBox="0 0 320 1440" preserveAspectRatio="none">
          <path d="M40,0 C0,120 80,240 40,360 C0,480 80,600 40,720 C0,840 80,960 40,1080 C0,1200 80,1320 40,1440 L320,1440 L320,0 Z" />
        </svg>
      </div>
      <div class="wave-side wave-side-2">
        <svg viewBox="0 0 320 1440" preserveAspectRatio="none">
          <path d="M40,0 C80,120 0,240 40,360 C80,480 0,600 40,720 C80,840 0,960 40,1080 C80,1200 0,1320 40,1440 L320,1440 L320,0 Z" />
        </svg>
      </div>
      <div class="wave-side wave-side-3">
        <svg viewBox="0 0 320 1440" preserveAspectRatio="none">
          <path d="M40,0 C0,120 80,240 40,360 C0,480 80,600 40,720 C0,840 80,960 40,1080 C0,1200 80,1320 40,1440 L320,1440 L320,0 Z" />
        </svg>
      </div>
      <div class="wave-side wave-side-4">
        <svg viewBox="0 0 320 1440" preserveAspectRatio="none">
          <path d="M40,0 C80,120 0,240 40,360 C80,480 0,600 40,720 C80,840 0,960 40,1080 C80,1200 0,1320 40,1440 L320,1440 L320,0 Z" />
        </svg>
      </div>
    </div>

    <div class="signup-panel" id="signup-panel">
      <button class="signup-panel-close" id="signup-close" type="button" aria-label="关闭">×</button>
      <h2 class="signup-panel-title">新生歌会</h2>
      <p class="signup-panel-subtitle">提交前请先阅读注意事项哦~</p>
      <form class="signup-panel-form" id="now-signup-form">
        <div id="now-form-fields"></div>
        <div id="now-attachment-field" class="signup-field" style="display:none">
          <label>附件<span class="required">*</span></label>
          <div class="signup-file-wrap" id="now-file-wrap">
            <input type="file" id="now-attachment" name="attachment" accept=".zip,.rar,.7z,.tar,.bz2,.tar.xz,.tar.gz,.tgz,application/zip,application/x-rar-compressed,application/x-7z-compressed" />
            <label for="now-attachment" class="signup-file-trigger">
              <span class="signup-file-icon">⇪</span>
              <span class="signup-file-text">点击或拖拽上传压缩包</span>
            </label>
            <div class="signup-file-list" id="now-file-list"></div>
          </div>
        </div>
        <div id="now-instructions" class="signup-panel-instructions" style="display:none">
          <h3>递交须知</h3>
          <div id="now-instructions-content"></div>
        </div>
        <button type="submit" class="signup-panel-submit">提交报名</button>
      </form>
      <p class="signup-panel-error" id="signup-panel-error" style="display:none">未获取到活动信息，无法报名</p>
    </div>

    <img class="signup-character" id="signup-character" src={activity002.src} alt="" draggable="false" />
  </div>

  <script>
    import "../../scripts/activity-now";
  </script>
</body>
</html>
