---
export interface Props {
  title: string;
  description?: string;
}

import "../styles/index.css";
import "../styles/gallery.css";
import "../styles/about.css";
import "../styles/calender.css";
import "../styles/activity.css";
import "../styles/activity-detail.css";
import "../styles/signup.css";

import Navigation from "../components/Navigation.astro";
import HomePage from "../components/HomePage.astro";
import LivePage from "../components/LivePage.astro";
import GalleryPage from "../components/GalleryPage.astro";
import ActivityPage from "../components/ActivityPage.astro";
import AboutPage from "../components/AboutPage.astro";
import DownloadPage from "../components/DownloadPage.astro";

const { title, description = "Huaxiaoke" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" sizes="32x32" href="/img/icon.ico" />
    <link rel="preload" as="style" href="/vendor/fontawesome/all.min.css" />
    <link rel="stylesheet" href="/vendor/fontawesome/all.min.css" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme') || 'dark';
        if (t === 'dark') document.documentElement.classList.add('dark');
        else document.documentElement.classList.remove('dark');
      })();
    </script>
  </head>

  <body>
    <canvas transition:persist="stars-canvas"></canvas>
    <Navigation />

    <main>
      <HomePage />
      <LivePage />
      <GalleryPage />
      <ActivityPage />
      <AboutPage />
      <DownloadPage />
    </main>

    <script>
      (function() {
        var p = window.location.pathname;
        if (p === '/' || p === '/index.html') return;
        var mapping = { '/live': 'live', '/gallery': 'gallery', '/activity': 'activity', '/about': 'about', '/download': 'download' };
        var page = mapping[p] || 'index';
        ['index','live','gallery','activity','about','download'].forEach(function(id) {
          var el = document.getElementById('page-' + id);
          if (el) el.style.display = id === page ? 'block' : 'none';
        });
      })();
    </script>

    <script src="/src/scripts/api-config.ts"></script>
    <script src="/src/scripts/spa-navigation.ts"></script>
    <script src="/src/scripts/staggered-menu.ts"></script>
    <script src="/src/scripts/imageGallery.ts"></script>
    <script src="/src/scripts/slide.ts"></script>
    <script src="/src/scripts/stars.ts"></script>
    <script src="/src/scripts/timeline.ts"></script>
    <script src="/src/scripts/dayornight.ts"></script>
    <script src="/src/scripts/isinline.ts"></script>
    <script src="/src/scripts/activity.ts"></script>
    <script src="/src/scripts/content-loader.ts"></script>
    <script src="/src/scripts/clickSpark.ts"></script>
    <script src="/src/scripts/card-swap.ts"></script>
  </body>
</html>
